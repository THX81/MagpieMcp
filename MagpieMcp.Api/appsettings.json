{
  "Defaults": {
    "RequestUserAgent": "McpSearchServer/1.0"
  },
  "Cors": {
    "Enabled": true,
    "AllowAnyOrigin": true,
    "AllowAnyMethod": true,
    "AllowAnyHeader": true
  },
  "McpTools": {
    "Tools": [
      {
        "Enabled": true,
        "Name": "web_search",
        "Description": "Performs a web search. Returns a list of results with title, url, and snippet.",
        "UrlTemplate": "http://localhost:8080/search?q={0}&format=json",
        "headers": {
          "x-api-key": "123"
        },
        "ResultLinkRegex": ""
      }
    ]
  },
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
